generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  todos         Todo[]
  timelineEntries TimelineEntry[]
  habits        Habit[]
  projects      Project[]
  highlights    DailyHighlight[]
  recurringRules RecurringRule[]
  notes         Note[]
  vaultConfig   VaultConfig?
  credentials   Credential[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  color       String   @default("#6366f1")
  goal        String?  @db.Text
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  todos       Todo[]
  sections    ProjectSection[]
}

model ProjectSection {
  id        String   @id @default(cuid())
  title     String
  isOpen    Boolean  @default(true)
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  todos     Todo[]
}

model Todo {
  id              String        @id @default(cuid())
  title           String
  description     String?       @db.Text
  completed       Boolean       @default(false)
  priority        String        @default("medium")
  urgent          Boolean       @default(false)
  date            DateTime?
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sectionId       String?
  section         ProjectSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  recurringRuleId String?
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model TimelineEntry {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  startTime       String
  endTime         String?
  title           String
  description     String?  @db.Text
  category        String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  recurringRuleId  String?
  recurringRule    RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: Cascade)
  hideFromMonthly  Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model RecurringRule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  freq        String
  weekDays    String?
  monthDay    Int?
  title       String
  startTime   String?
  endTime     String?
  category    String?
  createdAt   DateTime  @default(now())
  todos       Todo[]
  timelineEntries TimelineEntry[]
}

model Habit {
  id        String      @id @default(cuid())
  name      String
  emoji     String?
  color     String      @default("#10b981")
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  logs      HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

model DailyHighlight {
  id        String   @id @default(cuid())
  userId    String
  date      String
  content   String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   String   @db.LongText
  tags      String?  @db.Text
  date      String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
}

model VaultConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  salt      String
  verifier  String   @db.LongText
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Credential {
  id             String   @id @default(cuid())
  userId         String
  name           String
  type           String   @default("password")
  encryptedValue String   @db.LongText
  iv             String
  description    String?
  pinned         Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
